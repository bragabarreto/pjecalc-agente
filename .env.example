# .env.example — Variáveis de ambiente do Agente PJE-Calc
# NUNCA versionar o arquivo .env real. Copie este arquivo para .env e preencha.

# ── Obrigatório ───────────────────────────────────────────────────────────────

# Chave da API Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-SUBSTITUA_PELA_SUA_CHAVE

# ── PJE-Calc Cidadão (modo local — Mac/Windows) ───────────────────────────────

# URL do PJE-Calc instalado na sua máquina.
# Versão bundled (pjecalc-dist/ deste repo) → porta 9257:
PJECALC_LOCAL_URL=http://localhost:9257/pjecalc

# Instalação padrão baixada do site do TRT → porta 8080:
# PJECALC_LOCAL_URL=http://localhost:8080/pje-calc

# Tempo máximo (segundos) para aguardar o PJE-Calc inicializar antes da automação.
# Modo local (você já abriu o PJE-Calc): 30s
PJECALC_TOMCAT_TIMEOUT=30
# Modo Railway/Docker (Tomcat sobe junto): 600s
# PJECALC_TOMCAT_TIMEOUT=600

# Diretório do PJE-Calc (usado para inicialização automática via script).
# Deixe o padrão se usar pjecalc-dist/ deste repositório.
# PJECALC_DIR=/caminho/para/seu/pjecalc

# ── Banco de Dados ────────────────────────────────────────────────────────────

# Produção (Railway injeta automaticamente ao adicionar serviço PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_banco

# Local (padrão, SQLite):
# DATABASE_URL=sqlite:///data/pjecalc_agent.db

# ── Armazenamento de arquivos ─────────────────────────────────────────────────

# Diretório de dados persistentes (Railway: montar volume em /app/data)
# DATA_DIR=/app/data

# ── Comportamento ─────────────────────────────────────────────────────────────

# Modo cloud: false = automação habilitada (padrão quando Playwright instalado)
#             true  = desativa automação (Railway/nuvem sem display)
CLOUD_MODE=false

# Porta do servidor web (Railway injeta automaticamente):
# PORT=8000
